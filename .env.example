# ─── HACKLAUNCH SYSTEM ENVIRONMENT VARIABLES ─────────────────────────────────

# ─── Application settings
APP_ENV=development
APP_NAME="HackLaunch AI"
APP_SECRET_KEY=generate_random_key_here
APP_DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://hacklaunch:password@localhost:5432/hacklaunch_db

# ─── JWT Authentication
JWT_SECRET_KEY=generate_random_jwt_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Google OAuth Credentials (optional for OAuth login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── Redis Caching & Queue
REDIS_URL=redis://localhost:6379/0

# ─── Google GenAI / Gemini API (required)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Qdrant Vector database (required for Long-Term Memory)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=optional_key_here
QDRANT_COLLECTION_EVENTS=hacklaunch_events

# ─── SMTP Email settings (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@hacklaunch.ai
